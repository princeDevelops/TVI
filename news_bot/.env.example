# ── AI providers ─────────────────────────────────────────────────────────────
# Groq is primary. Gemini is fallback when Groq hits its daily rate limit.
# Get Groq key: console.groq.com
# Get Gemini key: aistudio.google.com (free, no card needed)
GROQ_API_KEY=
GEMINI_API_KEY=

# ── Discord Webhook URLs ──────────────────────────────────────────────────────
# Create one webhook per channel in your Discord server.
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL

